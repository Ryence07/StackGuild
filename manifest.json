{
  "manifest_version": 3,
  "name": "StackGuild - Price Monitor",
  "version": "1.0.0",
  "description": "Monitors product prices on Shopee Philippines and Lazada Philippines using rule-based DOM parsing. All data stored locally for privacy.",

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
  "*://*.shopee.ph/*",
  "*://*.lazada.com.ph/*"
 ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.shopee.ph/*",
        "*://*.lazada.com.ph/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "StackGuild Price Monitor"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": [
        "*://*.shopee.ph/*",
        "*://*.lazada.com.ph/*"
      ]
    }
  ]
}
